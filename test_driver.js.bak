import { spawn } from 'child_process';
import path from 'path';

const serverPath = 'D:/windows-computer-use-mcp/bundle/index.js';
let requestId = 0;

async function callTool(server, method, params, timeoutMs = 30000) {
  return new Promise((resolve, reject) => {
    const id = ++requestId;
    const request = {
      jsonrpc: '2.0',
      id,
      method,
      params
    };

    server.stdin.write(JSON.stringify(request) + '\n');

    const timer = setTimeout(() => {
      server.stdout.removeListener('data', onData);
      reject(new Error(`Timeout after ${timeoutMs}ms`));
    }, timeoutMs);

    let buffer = '';
    const onData = (data) => {
      const chunk = data.toString();
      console.log(`[DEBUG] Received chunk length: ${chunk.length}, preview: ${chunk.substring(0, 50)}`);
      buffer += chunk;

      const lines = buffer.split('\n');
      buffer = lines.pop() || ''; // Keep the last (potentially incomplete) part in buffer

      for (const line of lines) {
        const trimmed = line.trim();
        if (!trimmed) continue;
        try {
          const response = JSON.parse(trimmed);
          if (response.id === id) {
            clearTimeout(timer);
            server.stdout.removeListener('data', onData);
            if (response.error) {
              reject(new Error(response.error.message || 'Unknown error'));
            } else {
              resolve(response.result);
            }
            return;
          }
        } catch (e) {
          console.error(`[DEBUG] JSON parse error: ${e.message}, line: ${trimmed}`);
        }
      }
    };

    server.stdout.on('data', onData);
  });
}

async function runAutomatedTest() {
  console.log('====================================================');
  console.log('🚀 STARTING AUTOMATED FUNCTIONAL TEST SUITE');
  console.log('====================================================');

  const server = spawn('node', [serverPath]);

  server.stderr.on('data', (data) => {
    const msg = data.toString();
    if (!msg.includes('JSON-RPC')) {
      console.log(`[Server Log] ${msg.trim()}`);
    }
  });

  try {
    // --- 1. 基础连接与尺寸测试 ---
    console.log('\n[STEP 1] Testing get_display_size...');
    const displaySize = await callTool(server, 'tools/call', {
      name: 'get_display_size',
      arguments: {}
    });
    console.log('✅ Success:', JSON.stringify(displaySize));

    // --- 2. 截图测试 ---
    console.log('\n[STEP 2] Testing screenshot...');
    const screenshot = await callTool(server, 'tools/call', {
      name: 'screenshot',
      arguments: { exclude: [] }
    });
    console.log('✅ Success: Received screenshot (Base64 length:', screenshot.content[0].text.length, ')');
    console.log('💡 ACTION REQUIRED: Please convert the base64 to an image and check if it is valid.');

    // --- 2.5 极端移动测试 (验证鼠标驱动是否失效) ---
    console.log('\n[STEP 2.5] EXTREME MOUSE TEST: Moving from top-left to bottom-right...');
    try {
        // 假设屏幕是 2560x1440，我们从 100,100 移到 2400,1300
        await callTool(server, 'tools/call', {
            name: 'move_mouse',
            arguments: { x: 100, y: 100 }
        });
        await new Promise(r => setTimeout(r, 500));
        await callTool(server, 'tools/call', {
            name: 'move_mouse',
            arguments: { x: 2400, y: 1300 }
        });
        console.log('✅ Extreme move command sent successfully.');
    } catch (e) {
        console.log(`⚠️ Extreme move failed: ${e.message}`);
    }

    // --- 3. 应用启动与输入测试 ---
    console.log('\n[STEP 3] Testing open_app (notepad.exe)...');
    await callTool(server, 'tools/call', {
      name: 'open_app',
      arguments: { path: 'notepad.exe' }
    });
    console.log('✅ Success: Notepad should be opening now.');
    console.log('⏳ Waiting 2 seconds for app to stabilize...');
    await new Promise(r => setTimeout(r, 2000));

    // --- 4. 键入测试 ---
    console.log('\n[STEP 4] Testing type ("Hello from Computer Use!")...');
    await callTool(server, 'tools/call', {
      name: 'type',
      arguments: { text: 'Hello from Computer Use!' }
    });
    console.log('✅ Success: Text should be typed into Notepad.');

    console.log('\n[STEP 5] Testing key (ctrl+s)...');
    await callTool(server, 'tools/call', {
      name: 'key',
      arguments: { sequence: 'ctrl+s' }
    });
    console.log('✅ Success: Ctrl+S sent. (Note: This may trigger a save dialog)');

    // --- 5. 剪贴板测试 ---
    console.log('\n[STEP 6] Testing clipboard (write & read)...');
    const testString = 'Clipboard test ' + Date.now();
    await callTool(server, 'tools/call', {
      name: 'write_clipboard',
      arguments: { text: testString }
    });
    console.log(`✅ Success: Wrote "${testString}" to clipboard.`);

    const clipboardResponse = await callTool(server, 'tools/call', {
      name: 'read_clipboard',
      arguments: {}
    });
    console.log('✅ Read Result:', JSON.stringify(clipboardResponse, null, 2));

    // 修复后的验证逻辑
    const actualText = clipboardResponse.content[0].text.replace(/["']/g, "");
    if (actualText.includes(testString)) {
      console.log('✨ Clipboard verification MATCHED!');
    } else {
      console.log('❌ Clipboard verification FAILED!');
    }

    // --- 6. 应用状态测试 ---
    console.log('\n[STEP 7] Testing get_frontmost_app...');
    const appInfo = await callTool(server, 'tools/call', {
      name: 'get_frontmost_app',
      arguments: {}
    });
    console.log('✅ Success:', JSON.stringify(appInfo));

    console.log('\n====================================================');
    console.log('🎉 AUTOMATED TEST SEQUENCE COMPLETED');
    console.log('====================================================');

  } catch (err) {
    console.error('\n❌ TEST SUITE CRASHED!');
    console.error('Error details:', err.message);
    console.log('\n💡 Please check if the error is related to coordinates or permissions.');
  } finally {
    console.log('\nCleaning up server...');
    server.kill();
    console.log('Done.');
  }
}

runAutomatedTest();
