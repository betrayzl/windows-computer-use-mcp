// 与现有 macOS 版本保持一致的接口定义
export interface DisplayGeometry {
  width: number;
  height: number;
  scaleFactor: number;
}

export interface ScreenshotResult {
  base64: string;
  width: number;
  height: number;
}

export interface FrontmostApp {
  bundleId?: string; // Windows 下可映射为进程路径
  displayName: string;
}

export interface InstalledApp {
  displayName: string;
  path?: string;
}

// ComputerExecutor 接口
export interface ComputerExecutor {
  getDisplaySize(): Promise<DisplayGeometry>;
  screenshot(opts: { excludeProcessNames?: string[] }): Promise<ScreenshotResult>;
  moveMouse(x: number, y: number): Promise<void>;
  click(x: number, y: number, button: 'left' | 'right' | 'middle', count?: number): Promise<void>;
  drag(from: { x: number; y: number } | undefined, to: { x: number; y: number }): Promise<void>;
  scroll(x: number, y: number, dx: number, dy: number): Promise<void>;
  key(sequence: string): Promise<void>;
  type(text: string): Promise<void>;
  getFrontmostApp(): Promise<FrontmostApp | null>;
  hideWindows(processNames: string[]): Promise<number[]>;
  unhideWindows(handles: number[]): Promise<void>;
  listInstalledApps(): Promise<InstalledApp[]>;
  openApp(path: string): Promise<void>;
  readClipboard(): Promise<string>;
  writeClipboard(text: string): Promise<void>;
}
