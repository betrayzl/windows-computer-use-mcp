/**
 * 逻辑坐标 (Logical) 与 物理坐标 (Physical) 之间的转换
 * Windows 下，逻辑坐标是用户看到的，物理坐标是实际像素。
 * 物理坐标 = 逻辑坐标 * 缩放比例 (DPI Scale)
 */

export function logicalToPhysical(x: number, y: number, scaleFactor: number): { x: number; y: number } {
  return {
    x: Math.round(x * scaleFactor),
    y: Math.round(y * scaleFactor),
  };
}

export function physicalToLogical(x: number, y: number, scaleFactor: number): { x: number; y: number } {
  return {
    x: Math.round(x / scaleFactor),
    y: Math.round(y / scaleFactor),
  };
}

/**
 * 获取当前的 DPI 缩放比例。
 * 在开发环境下，如果无法通过 Windows API 获取，可以返回一个默认值。
 * 注意：在实际生产环境中，应通过调用原生模块来获取准确的缩放比例。
 */
export function getDpiScale(): number {
  // 占位实现。实际应用中，应该从原生模块或 Windows API 获取。
  // 这里为了让项目能跑起来，默认返回 1.0。
  // 待后续集成原生 API 获取真实 DPI。
  return 1.0;
}
